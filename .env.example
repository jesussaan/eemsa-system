REACT_APP_SUPABASE_URL=
REACT_APP_SUPABASE_KEY=

# Push notifications PWA (VAPID)
REACT_APP_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:admin@eemsa.com.mx

# Supabase service role key (solo server-side, para leer suscripciones push)
SUPABASE_SERVICE_KEY=

# CallMeBot WhatsApp (https://www.callmebot.com/blog/free-api-whatsapp-messages/)
REACT_APP_CALLMEBOT_PHONE=
REACT_APP_CALLMEBOT_APIKEY=

# Protege /api/notificar contra uso externo no autorizado (email/push).
# Define el mismo valor en CHAT_API_SECRET (server) y REACT_APP_CHAT_API_SECRET (build del frontend).
# /api/chat NO usa esto -- se protege con el token de sesion (ver SESSION_SECRET abajo).
CHAT_API_SECRET=
REACT_APP_CHAT_API_SECRET=

# Dominio de produccion permitido para CORS en /api/chat (opcional, default: https://eemsa-system.vercel.app)
ALLOWED_ORIGIN=

# Clave para firmar tokens de sesion (Modo Supervisor / Cotizador / api/chat). Requerida.
SESSION_SECRET=

# PIN de acceso a Modo Supervisor / Cotizador (default 2312 si no se define)
PIN_SUPERVISOR=
PIN_COTIZADOR=
